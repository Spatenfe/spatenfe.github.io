---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter((project) => !project.data.links?.projectPage)
    .map((project) => ({
      params: { slug: project.slug },
      props: { project }
    }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props as Props;
const { Content } = await render(project);
const { title, description, date, tags, image, bannerImage, bannerPadding, category, bibtex, authors } = project.data;
const links = project.data.links ?? {};
const banner = bannerImage ?? image;
const backHref = withBase(category === 'research' ? '/#research' : '/#projects');
const writeupHref = links.writeup?.startsWith('/') ? withBase(links.writeup) : links.writeup;

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': category === 'research' ? 'ScholarlyArticle' : 'CreativeWork',
  headline: title,
  description,
  datePublished: date.toISOString().split('T')[0],
  keywords: tags.join(', '),
  author: (authors ?? []).map((author) => ({ '@type': 'Person', name: author.name.replace(/\*+$/, '').trim() })),
  url: Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined,
  sameAs: [links.paper, links.github, links.demo].filter(Boolean)
};
---

<BaseLayout title={`${title} | Project`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(projectSchema)} />
  <Navbar />
  <main id="main-content" class="container-page section-spacing">
    <a href={backHref} class="text-sm font-semibold text-accent hover:underline">← Back to Projects</a>
    <SectionHeader title={title} subtitle={description} authors={authors} as="h1" />

    <article class="surface-card overflow-hidden">
      <div class:list={['border-b border-border', bannerPadding && 'px-6 sm:px-8']}>
        <img
          src={withBase(banner)}
          alt={title}
          class={bannerImage
            ? 'w-full object-contain'
            : 'h-56 w-full object-cover sm:h-80'}
        />
      </div>
      <div class="p-6 sm:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="font-mono text-sm font-semibold uppercase tracking-wide text-ink">{date.getFullYear()}</span>
          {tags.map((tag) => (
            <span class="rounded-md border border-border bg-bg px-2 py-1 font-mono text-xs text-muted">{tag}</span>
          ))}
        </div>

        <div class="mt-5 flex flex-wrap gap-4 text-sm">
          {links.paper && (
            <a href={links.paper} class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline" target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h6z"/></svg>
              Paper
            </a>
          )}
          {links.github && (
            <a href={links.github} class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline" target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-current" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58l-.01-2.05c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.1-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.08 1.84 2.82 1.31 3.5 1 .11-.79.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.9 0-1.3.47-2.37 1.24-3.2-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.22a11.4 11.4 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.65.24 2.87.12 3.17.77.83 1.24 1.9 1.24 3.2 0 4.58-2.81 5.59-5.49 5.89.43.38.82 1.11.82 2.24l-.01 3.32c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/></svg>
              Code
            </a>
          )}
          {links.demo && (
            <a href={links.demo} class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline" target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Demo
            </a>
          )}
          {links.writeup && (
            <a href={writeupHref} class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline" target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              Write-up
            </a>
          )}
        </div>

        <div class="prose prose-slate mt-8 max-w-none prose-headings:font-display prose-headings:tracking-tight prose-a:text-accent">
          <Content />
        </div>

        {bibtex && (
          <span id="bibtex-button-slot" class="hidden">
            <button
              type="button"
              data-copy-bibtex={bibtex}
              class="copy-bibtex-btn ml-2 inline-flex -translate-y-px items-center gap-1.5 rounded-md border border-border bg-surface px-2 py-1 align-middle font-mono text-xs font-semibold text-ink transition hover:border-ink"
            >
              <svg viewBox="0 0 24 24" class="h-3 w-3 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span class="copy-bibtex-label">Copy BibTeX</span>
            </button>
          </span>
        )}
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<script>
  const bibtexAnchor = document.getElementById('bibtex-anchor');
  const bibtexButtonSlot = document.getElementById('bibtex-button-slot');
  const bibtexButton = bibtexButtonSlot?.querySelector('.copy-bibtex-btn');
  if (bibtexAnchor && bibtexButton) {
    bibtexAnchor.replaceWith(bibtexButton);
  }

  document.querySelectorAll('[data-copy-bibtex]').forEach((button) => {
    button.addEventListener('click', async () => {
      const bibtex = button.getAttribute('data-copy-bibtex') || '';
      const label = button.querySelector('.copy-bibtex-label');
      const original = label?.textContent ?? 'Copy BibTeX';

      try {
        await navigator.clipboard.writeText(bibtex);
        if (label) label.textContent = 'Copied!';
      } catch (err) {
        console.error('Failed to copy BibTeX', err);
        if (label) label.textContent = 'Copy failed';
      }

      setTimeout(() => {
        if (label) label.textContent = original;
      }, 1500);
    });
  });
</script>
