---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ScrollSpySidebar from '../components/ScrollSpySidebar.astro';
import Timeline from '../components/Timeline.astro';
import NewsFeed from '../components/NewsFeed.astro';
import { techGroups } from '../data/tech';
import { experience } from '../data/experience';
import { education } from '../data/education';
import { profileDetails } from '../data/profile';
import { news } from '../data/news';
import { siteData } from '../data/site';

const allProjects = (await getCollection('projects')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const researchProjects = allProjects.filter((project) => project.data.featured && project.data.category === 'research');
const otherProjects = allProjects.filter((project) => project.data.featured && project.data.category === 'project');

const experienceItems = experience.map((item) => ({
  title: item.company,
  subtitle: `${item.role} · ${item.location}`,
  meta: `${item.start} — ${item.end}`,
  bullets: item.bullets,
  chips: item.tech
}));

const educationItems = education.map((item) => ({
  title: item.degree,
  subtitle: `${item.university} · ${item.location}`,
  meta: `${item.start} — ${item.end}`,
  bullets: item.highlights,
  chips: []
}));

const personalCards = [
  { title: 'Languages', items: profileDetails.languages },
  { title: 'Passions', items: profileDetails.passions }
];

const sidebarItems = [
  { ids: ['news'], label: 'News' },
  { ids: ['research'], label: 'Research Highlights' },
  ...(otherProjects.length > 0 ? [{ ids: ['projects'], label: 'Projects' }] : []),
  { ids: ['experience', 'education'], label: 'Experience & Education' },
  { ids: ['stack', 'personal'], label: 'Personal & Tech Stack' }
];
---

<BaseLayout>
  <Navbar />
  <ScrollSpySidebar items={sidebarItems} />
  <main class="container-page content-with-toc pb-8">
    <Hero />

    <section id="news" class="section-spacing">
      <SectionHeader title="News" />
      <NewsFeed items={news} />
    </section>

    <section id="research" class="section-spacing">
      <SectionHeader
        title="Research Highlights"
        subtitle="A selection of projects that display the highlights of my work."
      />
      <div class="relative">
        <div id="featured-project-grid" class="scrollbar-hide flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth py-3">
          {researchProjects.map((project) => (
            <div class="w-full shrink-0 snap-start md:w-[calc(50%-0.75rem)] xl:w-[calc((100%-3rem)/3)]">
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
        <div data-scroll-fade-left="featured-project-grid" class="pointer-events-none absolute inset-y-3 left-0 w-12 bg-gradient-to-r from-bg to-transparent opacity-0 transition-opacity duration-300 sm:w-20"></div>
        <div data-scroll-fade-right="featured-project-grid" class="pointer-events-none absolute inset-y-3 right-0 w-12 bg-gradient-to-l from-bg to-transparent opacity-0 transition-opacity duration-300 sm:w-20"></div>
        {researchProjects.length > 1 && (
          <>
            <button type="button" data-scroll-prev="featured-project-grid" aria-label="Scroll left" class="absolute left-0 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 rounded-full border border-border bg-surface p-2 shadow-soft transition hover:border-ink sm:flex">
              <svg viewBox="0 0 24 24" class="h-4 w-4 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button type="button" data-scroll-next="featured-project-grid" aria-label="Scroll right" class="absolute right-0 top-1/2 hidden -translate-y-1/2 translate-x-1/2 rounded-full border border-border bg-surface p-2 shadow-soft transition hover:border-ink sm:flex">
              <svg viewBox="0 0 24 24" class="h-4 w-4 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </>
        )}
      </div>
    </section>

    {otherProjects.length > 0 && (
      <section id="projects" class="section-spacing">
        <SectionHeader
          title="Projects"
          subtitle="Independent builds and tools outside of published research."
        />
        <div class="relative">
          <div id="other-project-grid" class="scrollbar-hide flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth py-3">
            {otherProjects.map((project) => (
              <div class="w-full shrink-0 snap-start md:w-[calc(50%-0.75rem)] xl:w-[calc((100%-3rem)/3)]">
                <ProjectCard project={project} />
              </div>
            ))}
          </div>
          <div data-scroll-fade-left="other-project-grid" class="pointer-events-none absolute inset-y-3 left-0 w-12 bg-gradient-to-r from-bg to-transparent opacity-0 transition-opacity duration-300 sm:w-20"></div>
          <div data-scroll-fade-right="other-project-grid" class="pointer-events-none absolute inset-y-3 right-0 w-12 bg-gradient-to-l from-bg to-transparent opacity-0 transition-opacity duration-300 sm:w-20"></div>
          {otherProjects.length > 1 && (
            <>
              <button type="button" data-scroll-prev="other-project-grid" aria-label="Scroll left" class="absolute left-0 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 rounded-full border border-border bg-surface p-2 shadow-soft transition hover:border-ink sm:flex">
                <svg viewBox="0 0 24 24" class="h-4 w-4 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button type="button" data-scroll-next="other-project-grid" aria-label="Scroll right" class="absolute right-0 top-1/2 hidden -translate-y-1/2 translate-x-1/2 rounded-full border border-border bg-surface p-2 shadow-soft transition hover:border-ink sm:flex">
                <svg viewBox="0 0 24 24" class="h-4 w-4 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </>
          )}
        </div>
      </section>
    )}

    <script>
      const equalizeProjectCards = (gridId) => {
        const grid = document.getElementById(gridId);
        if (!grid) return;

        const descriptions = Array.from(grid.querySelectorAll('[data-project-description]'));
        const cards = Array.from(grid.querySelectorAll('[data-project-card]'));
        if (!descriptions.length || !cards.length) return;

        descriptions.forEach((el) => {
          el.style.minHeight = '0px';
        });
        cards.forEach((el) => {
          el.style.minHeight = '0px';
        });

        const maxDescriptionHeight = Math.max(...descriptions.map((el) => el.getBoundingClientRect().height));
        descriptions.forEach((el) => {
          el.style.minHeight = `${maxDescriptionHeight}px`;
        });

        const maxCardHeight = Math.max(...cards.map((el) => el.getBoundingClientRect().height));
        cards.forEach((el) => {
          el.style.minHeight = `${maxCardHeight}px`;
        });
      };

      const runEqualize = () => ['featured-project-grid', 'other-project-grid'].forEach(equalizeProjectCards);
      runEqualize();
      window.addEventListener('resize', runEqualize);

      const wireScrollRow = (gridId) => {
        const row = document.getElementById(gridId);
        const prevButton = document.querySelector(`[data-scroll-prev="${gridId}"]`);
        const nextButton = document.querySelector(`[data-scroll-next="${gridId}"]`);
        const fadeLeft = document.querySelector(`[data-scroll-fade-left="${gridId}"]`);
        const fadeRight = document.querySelector(`[data-scroll-fade-right="${gridId}"]`);
        if (!row) return;

        const updateButtons = () => {
          const maxScroll = row.scrollWidth - row.clientWidth;
          const atStart = row.scrollLeft <= 1;
          const atEnd = row.scrollLeft >= maxScroll - 1;
          prevButton?.classList.toggle('invisible', atStart);
          nextButton?.classList.toggle('invisible', atEnd);
          fadeLeft?.classList.toggle('opacity-0', atStart);
          fadeRight?.classList.toggle('opacity-0', atEnd);
        };

        prevButton?.addEventListener('click', () => row.scrollBy({ left: -row.clientWidth, behavior: 'smooth' }));
        nextButton?.addEventListener('click', () => row.scrollBy({ left: row.clientWidth, behavior: 'smooth' }));
        row.addEventListener('scroll', updateButtons, { passive: true });
        window.addEventListener('resize', updateButtons);
        updateButtons();
      };

      ['featured-project-grid', 'other-project-grid'].forEach(wireScrollRow);
    </script>

    <section class="section-spacing">
      <div class="grid grid-cols-1 gap-10 xl:grid-cols-2 xl:gap-12">
        <div id="experience">
          <SectionHeader title="Work Experience" subtitle="Production-grade systems built across research and engineering teams." />
          <Timeline items={experienceItems} variant="experience" />
        </div>

        <div id="education">
          <SectionHeader title="Education" subtitle="Academic foundation in computer vision, AI, and machine learning." />
          <Timeline items={educationItems} variant="education" />
        </div>
      </div>
    </section>

    <section class="section-spacing">
      <div class="flex flex-col gap-10">
        <div id="stack">
          <SectionHeader title="Tech Stack" subtitle="Core tools for research throughput and production-grade system delivery." />
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {techGroups.map((group, idx) => (
              <article
                class="group reveal relative overflow-hidden rounded-2xl border border-border bg-surface p-5 transition duration-300 hover:-translate-y-1 hover:shadow-card sm:p-6"
              >
                <div
                  class={`pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100 ${
                    idx === 0
                      ? 'bg-gradient-to-br from-blue-100/40 to-transparent'
                      : idx === 1
                        ? 'bg-gradient-to-br from-indigo-100/40 to-transparent'
                        : idx === 2
                          ? 'bg-gradient-to-br from-teal-100/40 to-transparent'
                          : 'bg-gradient-to-br from-slate-100/40 to-transparent'
                  }`}
                ></div>
                <div class="relative z-10">
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <span
                        class={`rounded-lg border p-2 ${
                          idx === 0
                            ? 'border-blue-200/50 bg-blue-50/50 text-blue-700'
                            : idx === 1
                              ? 'border-indigo-200/50 bg-indigo-50/50 text-indigo-700'
                              : idx === 2
                                ? 'border-teal-200/50 bg-teal-50/50 text-teal-700'
                                : 'border-slate-200/50 bg-slate-50/50 text-slate-700'
                        }`}
                      >
                        {
                          idx === 0 ? (
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                              <path d="M4 12h16M12 4v16" />
                              <circle cx="12" cy="12" r="8" />
                            </svg>
                          ) : idx === 1 ? (
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                              <path d="M8 9l-3 3 3 3M16 9l3 3-3 3M14 6l-4 12" />
                            </svg>
                          ) : idx === 2 ? (
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                              <rect x="3.5" y="5" width="17" height="5" rx="1.5" />
                              <rect x="3.5" y="14" width="17" height="5" rx="1.5" />
                            </svg>
                          ) : (
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                              <path d="M4 16l4-4 3 3 5-5 4 4" />
                              <path d="M4 20h16" />
                            </svg>
                          )
                        }
                      </span>
                      <h3 class="text-base font-semibold text-ink">{group.title}</h3>
                    </div>
                  </div>
                  <ul class="mt-4 flex flex-wrap gap-2 text-sm text-muted">
                    {group.items.map((item) => (
                      <li
                        class={`rounded-lg border bg-bg px-3 py-1.5 transition group-hover:text-ink ${
                          idx === 0
                            ? 'border-border group-hover:border-blue-200/60'
                            : idx === 1
                              ? 'border-border group-hover:border-indigo-200/60'
                              : idx === 2
                                ? 'border-border group-hover:border-teal-200/60'
                                : 'border-border group-hover:border-slate-300/60'
                        }`}
                      >
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div id="personal">
          <SectionHeader title="Personal" subtitle="Languages and interests." />
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {personalCards.map((card, idx) => (
              <article
                class="group reveal relative overflow-hidden rounded-2xl border border-border bg-surface p-5 transition duration-300 hover:-translate-y-1 hover:shadow-card sm:p-6"
              >
                <div
                  class={`pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100 ${
                    idx === 0
                      ? 'bg-gradient-to-tr from-indigo-100/40 to-transparent'
                      : 'bg-gradient-to-tr from-rose-100/40 to-transparent'
                  }`}
                ></div>
                <div class="relative z-10">
                  <div class="flex items-center gap-3">
                    <span
                      class={`rounded-lg border p-2 ${
                        idx === 0
                          ? 'border-indigo-200/50 bg-indigo-50/50 text-indigo-700'
                          : 'border-rose-200/50 bg-rose-50/50 text-rose-700'
                      }`}
                    >
                      {
                        idx === 0 ? (
                          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M4 7h10M4 12h16M4 17h9" />
                          </svg>
                        ) : (
                          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M12 21s-7-4.3-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.7-7 10-7 10Z" />
                          </svg>
                        )
                      }
                    </span>
                    <h3 class="text-base font-semibold text-ink">{card.title}</h3>
                  </div>
                  <ul class="mt-4 flex flex-wrap gap-2 text-sm text-muted">
                    {card.items.map((item) => (
                      <li
                        class={`rounded-lg border bg-bg px-3 py-1.5 transition group-hover:text-ink ${
                          idx === 0 ? 'border-border group-hover:border-indigo-200/60' : 'border-border group-hover:border-rose-200/60'
                        }`}
                      >
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-spacing">
      <div class="reveal flex flex-col items-center gap-4 p-8 text-center sm:p-12">
        <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">Always happy to get in touch!</h2>
        <p class="max-w-md text-sm text-muted sm:text-base">
          Whether it's research, collaboration, or just a good conversation about Deep Learning. Feel free to reach out.
        </p>
        <div class="mt-2 flex flex-wrap justify-center gap-3">
          {siteData.email && (
            <a
              href={`mailto:${siteData.email}`}
              class="inline-flex items-center gap-2 rounded-lg border border-accent bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent-dark"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
              {siteData.email}
            </a>
          )}
          <a
            href={siteData.linkedinUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-ink"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.58c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.68H9.35V9h3.4v1.56h.05c.47-.9 1.63-1.86 3.35-1.86 3.59 0 4.25 2.36 4.25 5.43v6.32zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77A1.77 1.77 0 0 0 0 1.77v20.46C0 23.2.8 24 1.77 24h20.46A1.77 1.77 0 0 0 24 22.23V1.77A1.77 1.77 0 0 0 22.23 0z"/></svg>
            Connect on LinkedIn
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
