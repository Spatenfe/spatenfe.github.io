---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/withBase';
import AuthorList from './AuthorList.astro';

interface Props {
  publications: CollectionEntry<'projects'>[];
}

const { publications } = Astro.props;
---

<ol class="reveal flex flex-col gap-4 py-2">
  {publications.map((pub) => {
    const { title, description, date, venue, image, authors, bibtex } = pub.data;
    const links = pub.data.links ?? {};
    const href = links.projectPage ?? withBase(`/projects/${pub.slug}`);
    const writeupHref = links.writeup?.startsWith('/') ? withBase(links.writeup) : links.writeup;
    return (
      <li>
        <article class="surface-card flex flex-col gap-5 p-5 transition duration-200 hover:shadow-card sm:flex-row sm:gap-6 sm:p-6">
          <img
            src={withBase(image)}
            alt=""
            loading="lazy"
            class="w-full shrink-0 rounded-lg border border-border bg-bg object-contain p-2 sm:h-28 sm:w-44 sm:self-center"
          />
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2 font-mono text-xs">
              {venue && (
                <span class="rounded-md border border-border bg-bg px-2 py-1 font-semibold uppercase tracking-wide text-ink">{venue}</span>
              )}
              <span class="text-muted">{date.getFullYear()}</span>
            </div>
            <h3 class="mt-2 font-display text-lg font-semibold leading-snug text-ink sm:text-xl">
              <a
                href={href}
                target={links.projectPage ? '_blank' : undefined}
                rel={links.projectPage ? 'noreferrer' : undefined}
                class="transition-colors hover:text-accent hover:underline"
              >
                {title}
              </a>
            </h3>
            {authors && authors.length > 0 && <AuthorList authors={authors} class="mt-1" />}
            <p class="mt-2 text-sm leading-6 text-muted">{description}</p>
            <div class="mt-3 flex flex-wrap items-center gap-4 text-sm">
              <a
                href={href}
                target={links.projectPage ? '_blank' : undefined}
                rel={links.projectPage ? 'noreferrer' : undefined}
                class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline"
              >
                <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                {links.projectPage ? 'Paper Page' : 'Details'}
              </a>
              {links.github && (
                <a href={links.github} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-current" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58l-.01-2.05c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.1-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.08 1.84 2.82 1.31 3.5 1 .11-.79.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.9 0-1.3.47-2.37 1.24-3.2-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.22a11.4 11.4 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.65.24 2.87.12 3.17.77.83 1.24 1.9 1.24 3.2 0 4.58-2.81 5.59-5.49 5.89.43.38.82 1.11.82 2.24l-.01 3.32c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/></svg>
                  Code
                </a>
              )}
              {links.demo && (
                <a href={links.demo} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Demo
                </a>
              )}
              {links.writeup && (
                <a href={writeupHref} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  Write-up
                </a>
              )}
              {bibtex && (
                <button
                  type="button"
                  data-copy-bibtex={bibtex}
                  class="copy-bibtex-btn inline-flex items-center gap-1.5 rounded-md border border-border bg-surface px-2 py-1 font-mono text-xs font-semibold text-ink transition hover:border-ink"
                >
                  <svg viewBox="0 0 24 24" class="h-3 w-3 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  <span class="copy-bibtex-label">BibTeX</span>
                </button>
              )}
            </div>
          </div>
        </article>
      </li>
    );
  })}
</ol>

<script>
  if (!window.__bibtexCopyBound) {
    document.querySelectorAll('[data-copy-bibtex]').forEach((button) => {
      button.addEventListener('click', async () => {
        const bibtex = button.getAttribute('data-copy-bibtex') || '';
        const label = button.querySelector('.copy-bibtex-label');
        const original = label?.textContent ?? 'BibTeX';

        try {
          await navigator.clipboard.writeText(bibtex);
          if (label) label.textContent = 'Copied!';
        } catch (err) {
          console.error('Failed to copy BibTeX', err);
          if (label) label.textContent = 'Copy failed';
        }

        setTimeout(() => {
          if (label) label.textContent = original;
        }, 1500);
      });
    });

    window.__bibtexCopyBound = true;
  }
</script>
