---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/withBase';
import { getPngSize } from '../utils/imageSize';
import AuthorList from './AuthorList.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, tags, image, date, venue, imageFit, imagePadding, authors } = project.data;
const links = project.data.links ?? {};
const writeupHref = links.writeup?.startsWith('/') ? withBase(links.writeup) : links.writeup;
const tagDataset = tags.map((tag) => tag.toLowerCase()).join('|');
const isCurrentYear = date.getFullYear() === new Date().getFullYear();
const cardHref = links.projectPage ?? withBase(`/projects/${project.slug}`);
const imageSize = getPngSize(image);
---

<article
  class="project-card surface-card group flex h-full cursor-pointer flex-col transition duration-200 hover:-translate-y-1 hover:shadow-card"
  data-project-card
  data-project-url={cardHref}
  data-project-external={links.projectPage ? 'true' : undefined}
  data-tags={tagDataset}
  tabindex="0"
  role="link"
  aria-label={links.projectPage ? `${title} (opens external project page)` : title}
>
  <div class="relative overflow-hidden rounded-t-2xl">
    {imagePadding ? (
      <div class="border-b border-border px-6 sm:px-8">
        <img
          src={withBase(image)}
          alt={title}
          {...(imageSize ?? {})}
          class={imageFit === 'contain' ? 'w-full object-contain' : 'h-52 w-full object-cover'}
          loading="lazy"
        />
      </div>
    ) : (
      <img
        src={withBase(image)}
        alt={title}
        {...(imageSize ?? {})}
        class={imageFit === 'contain'
          ? 'w-full border-b border-border object-contain'
          : 'h-52 w-full border-b border-border object-cover'}
        loading="lazy"
      />
    )}
    {venue && (
      <span class="absolute left-3 top-3 rounded-md border border-red-200/60 bg-red-50/80 px-2 py-1 font-mono text-xs font-semibold text-red-700">
        {venue}
      </span>
    )}
    <span
      class={`absolute right-3 top-3 rounded-md border px-2 py-1 font-mono text-xs ${
        isCurrentYear
          ? 'border-emerald-200/60 bg-emerald-50/80 font-semibold text-emerald-700'
          : 'border-border bg-surface/95 text-muted'
      }`}
    >
      {date.getFullYear()}
    </span>
  </div>

  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <h3 class="font-display text-xl leading-tight text-ink sm:text-2xl">{title}</h3>
    {authors && authors.length > 0 && <AuthorList authors={authors} class="mt-1.5" />}
    <p class="mt-2 text-sm leading-6 text-muted" data-project-description>{description}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-md border border-border bg-bg px-2 py-1 font-mono text-xs text-muted">{tag}</span>
      ))}
    </div>

    <div class="mt-auto flex flex-wrap gap-4 pt-6 text-sm">
      {links.projectPage ? (
        <a href={links.projectPage} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Project Page
        </a>
      ) : (
        <a href={withBase(`/projects/${project.slug}`)} class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Details
        </a>
      )}
      {links.github && (
        <a href={links.github} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-current" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58l-.01-2.05c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.1-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.08 1.84 2.82 1.31 3.5 1 .11-.79.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.9 0-1.3.47-2.37 1.24-3.2-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.22a11.4 11.4 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.65.24 2.87.12 3.17.77.83 1.24 1.9 1.24 3.2 0 4.58-2.81 5.59-5.49 5.89.43.38.82 1.11.82 2.24l-.01 3.32c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/></svg>
          Code
        </a>
      )}
      {links.demo && (
        <a href={links.demo} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Demo
        </a>
      )}
      {links.writeup && (
        <a href={writeupHref} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 font-semibold text-accent hover:underline">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Write-up
        </a>
      )}
    </div>
  </div>
</article>

<script>
  if (!window.__projectCardNavigationBound) {
    const isInteractive = (target) => target instanceof Element && !!target.closest('a, button, input, select, textarea, label');

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (isInteractive(target)) return;

      const card = target instanceof Element ? target.closest('[data-project-url]') : null;
      const href = card?.getAttribute('data-project-url');
      if (!href) return;

      if (card.hasAttribute('data-project-external')) {
        window.open(href, '_blank', 'noopener,noreferrer');
      } else {
        window.location.href = href;
      }
    });

    document.addEventListener('keydown', (event) => {
      if (!(event.target instanceof Element)) return;
      if (isInteractive(event.target)) return;

      const card = event.target.closest('[data-project-url]');
      const href = card?.getAttribute('data-project-url');
      if (!href) return;

      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        if (card.hasAttribute('data-project-external')) {
          window.open(href, '_blank', 'noopener,noreferrer');
        } else {
          window.location.href = href;
        }
      }
    });

    window.__projectCardNavigationBound = true;
  }
</script>
