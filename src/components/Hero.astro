---
import { siteData } from '../data/site';
import { withBase } from '../utils/withBase';

const profileSrc = `${import.meta.env.BASE_URL}images/profile.jpg`;
const cvUrl = `${import.meta.env.BASE_URL}${siteData.cvPath}`;
---

<section id="home" class="section-spacing pb-8 sm:pb-12">
  <div class="surface-card reveal p-7 shadow-soft sm:p-10">
    <div class="grid gap-8 lg:grid-cols-[1fr_minmax(320px,520px)] lg:items-center">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-muted">Deep Learning • Multi Modality • Scaling Laws</p>
        <h1 class="mt-3 max-w-5xl font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">{siteData.name}</h1>
        <p class="mt-2 text-base font-medium text-ink/90">{siteData.title}</p>
        <p class="mt-4 max-w-3xl text-base leading-relaxed text-muted sm:text-lg">{siteData.tagline}</p>

        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted">
          <span class="inline-flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
            {siteData.location}
          </span>
          <div class="flex items-center gap-1.5">
            {siteData.email && (
              <a
                href={`mailto:${siteData.email}`}
                aria-label="Email"
                title={siteData.email}
                class="rounded-lg border border-transparent p-2 text-muted transition hover:border-border hover:bg-surface hover:text-ink"
              >
                <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
              </a>
            )}
            <a
              href={siteData.linkedinUrl}
              target="_blank"
              rel="noreferrer"
              aria-label="LinkedIn"
              title="LinkedIn"
              class="rounded-lg border border-transparent p-2 text-muted transition hover:border-border hover:bg-surface hover:text-ink"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.58c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.68H9.35V9h3.4v1.56h.05c.47-.9 1.63-1.86 3.35-1.86 3.59 0 4.25 2.36 4.25 5.43v6.32zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77A1.77 1.77 0 0 0 0 1.77v20.46C0 23.2.8 24 1.77 24h20.46A1.77 1.77 0 0 0 24 22.23V1.77A1.77 1.77 0 0 0 22.23 0z"/></svg>
            </a>
            <a
              href={siteData.githubUrl}
              target="_blank"
              rel="noreferrer"
              aria-label="GitHub"
              title="GitHub"
              class="rounded-lg border border-transparent p-2 text-muted transition hover:border-border hover:bg-surface hover:text-ink"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58l-.01-2.05c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.1-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.08 1.84 2.82 1.31 3.5 1 .11-.79.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.9 0-1.3.47-2.37 1.24-3.2-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.22a11.4 11.4 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.65.24 2.87.12 3.17.77.83 1.24 1.9 1.24 3.2 0 4.58-2.81 5.59-5.49 5.89.43.38.82 1.11.82 2.24l-.01 3.32c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/></svg>
            </a>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={withBase('/projects')}
            class="rounded-lg border border-accent bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#121a2d]"
          >
            Explore Research
          </a>
          <a
            href={cvUrl}
            download="CV_Felix_Foerster.pdf"
            class="rounded-lg border border-border bg-surface px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-ink"
          >
            Download CV
          </a>
        </div>
      </div>

      <div class="mx-auto h-[15.84rem] w-[15.84rem] overflow-hidden rounded-full border border-border bg-bg sm:h-[18.48rem] sm:w-[18.48rem] lg:mx-0 lg:justify-self-center">
        <img
          src={profileSrc}
          alt={`${siteData.name} profile`}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
