---
interface Props {
  items: { ids: string[]; label: string }[];
}

const { items } = Astro.props;
---

<aside
  class="pointer-events-none fixed left-6 top-1/2 z-40 hidden w-36 -translate-y-1/2 xl:block"
  aria-label="Section navigation"
>
  <ul class="pointer-events-auto space-y-3 border-l border-border">
    {items.map((item) => (
      <li>
        <a
          href={`#${item.ids[0]}`}
          data-scrollspy-link
          data-targets={item.ids.join(',')}
          class="-ml-px block border-l-2 border-transparent pl-4 text-xs leading-snug text-muted transition-colors duration-200 hover:text-ink"
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</aside>

<script>
  const links = Array.from(document.querySelectorAll('[data-scrollspy-link]'));

  const groups = links
    .map((link) => {
      const ids = (link.getAttribute('data-targets') || '').split(',').filter(Boolean);
      const els = ids.map((id) => document.getElementById(id)).filter(Boolean);
      return els.length ? { link, ids, els } : null;
    })
    .filter(Boolean);

  if (groups.length) {
    const setActive = (activeLink) => {
      groups.forEach(({ link }) => {
        const isActive = link === activeLink;
        link.classList.toggle('text-ink', isActive);
        link.classList.toggle('font-bold', isActive);
        link.classList.toggle('border-accent', isActive);
        link.classList.toggle('text-muted', !isActive);
        link.classList.toggle('border-transparent', !isActive);
      });
    };

    const visible = new Set();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            visible.add(entry.target.id);
          } else {
            visible.delete(entry.target.id);
          }
        });

        const active = groups.find(({ ids }) => ids.some((id) => visible.has(id)));
        if (active) setActive(active.link);
      },
      { rootMargin: '-15% 0px -70% 0px', threshold: 0 }
    );

    groups.forEach(({ els }) => els.forEach((el) => observer.observe(el)));
    setActive(groups[0].link);
  }
</script>
